@page "/users"
@using SharedLibrary.Interfaces
@using SharedLibrary.Dtos
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<h1 class="text-center mb-3">List of Users</h1>

@if (users == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>No.</th>
                <th>Email</th>
                <th>User Name</th>
                <th>Role</th>
            </tr>
        </thead>
        <tbody>
            @{
                int counter = 1;
            }
            @foreach (var user in users)
            {
                <tr>
                    <td>@counter</td>
                    <td>@user.Email</td>
                    <td>@user.UserName</td>
                    <td>@user.Role</td>
                </tr>
                counter++;
            }
        </tbody>
    </table>
}

@inject IUserAccount AccountService

@code {
    private IEnumerable<UserDto>? users;

    protected override async Task OnInitializedAsync()
    {
        users = await AccountService.GetAllUsers();
    }
}
